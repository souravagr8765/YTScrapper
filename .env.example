# Copy this file to .env and fill in your values
# Do NOT commit .env to source control

# --- Neon PostgreSQL ---
# Connection string from Neon dashboard (Settings > Connection Details)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# --- Nhost PostgreSQL ---
# Connection string from your Nhost project dashboard
NHOST_DATABASE_URL=postgresql://postgres:password@xxx.db.eu-central-1.nhost.run:5432/postgres
